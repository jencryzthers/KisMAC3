# KisMac3 release credentials — TEMPLATE (placeholders only, NO real values).
#
# Copy this file to .secrets/appstoreconnect.env and fill in your own values.
# The whole .secrets/ directory is gitignored: real credentials must NEVER be
# committed. Secrets are loaded from this file (or the system environment /
# Keychain) by the scripts in scripts/ — they are never hardcoded or echoed.
#
#   cp .secrets/appstoreconnect.env.example .secrets/appstoreconnect.env
#   chmod 600 .secrets/appstoreconnect.env
#   # then edit .secrets/appstoreconnect.env with your real values
#
# Place the App Store Connect API private key (.p8) here, NOT in this file:
#   .secrets/private_keys/AuthKey_<KEY_ID>.p8   (chmod 600)

# --- Developer ID code signing -------------------------------------------
# Apple Developer Team ID (10 chars). KisMac's project uses DMP42GVPJ3.
DEVELOPMENT_TEAM=

# Codesign identity. For distribution outside the App Store this must be a
# "Developer ID Application" certificate installed in your login Keychain, e.g.
#   Developer ID Application: Your Name (TEAMID)
# You can also pass the SHA-1 hash of the identity. Find it with:
#   security find-identity -v -p codesigning
CODESIGN_IDENTITY=

# --- App Store Connect API key (notarytool) ------------------------------
# Created at App Store Connect > Users and Access > Integrations > App Store
# Connect API. notarytool authenticates with these three values.
ASC_API_KEY_ID=
ASC_API_ISSUER_ID=
# Absolute or repo-relative path to the .p8 private key downloaded from ASC.
# Recommended location (gitignored): .secrets/private_keys/AuthKey_<KEY_ID>.p8
ASC_API_KEY_PATH=
