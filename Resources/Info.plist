	<key>CFBundleDevelopmentRegion</key>
	<string>English</string>
	<key>CFBundleDisplayName</key>
	<string>KisMac 2</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>kismac</string>
			</array>
			<key>CFBundleTypeIconFile</key>
			<string>devilDocument.icns</string>
			<key>CFBundleTypeName</key>
			<string>kismac</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSIsAppleDefaultForType</key>
			<true/>
			<key>LSTypeIsPackage</key>
			<false/>
		</dict>
		<dict>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>kismap</string>
			</array>
			<key>CFBundleTypeIconFile</key>
			<string>devilDocument.icns</string>
			<key>CFBundleTypeName</key>
			<string>kismap</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSIsAppleDefaultForType</key>
			<true/>
			<key>LSTypeIsPackage</key>
			<true/>
		</dict>
	</array>
	<key>CFBundleExecutable</key>
	<string>${EXECUTABLE_NAME}</string>
	<key>CFBundleGetInfoString</key>
	<string>KisMAC 0.3.4, © 2002-2013 Geoffrey Kruse &amp; KisMAC Community (Rewrited by Vitalii Parovishnyk &amp; IGR Software)</string>
	<key>CFBundleHelpBookFolder</key>
	<string>KisMACHelp</string>
